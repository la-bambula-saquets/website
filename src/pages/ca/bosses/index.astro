---
import BaseLayout from "../../../layouts/BaseLayout.astro";

const productModules = import.meta.glob("../../../content/products/*.md", {
  eager: true,
});

const products = Object.values(productModules)
  .map((module: any) => module.frontmatter)
  .sort((a: any, b: any) => (a.order ?? 999) - (b.order ?? 999));

const statusLabels: Record<string, string> = {
  available: "Disponible",
  sold: "Venut",
  made_to_order: "Per encàrrec",
};
---

<BaseLayout title="Bosses | La Bambula Saquets">
  <h2>Bosses</h2>

  {products.length === 0 ? (
    <p>Encara no hi ha productes publicats.</p>
  ) : (
    <div class="grid">
      {products.map((product: any) => (
        <article class="card">
          {product.main_image && (
            <img src={product.main_image} alt={product.name_ca} />
          )}

          <h3>
            <a href={`/ca/bosses/${product.slug}`}>
              {product.name_ca}
            </a>
          </h3>

          <p>{product.short_description_ca}</p>

          <p>
            <strong>Estat:</strong>{" "}
            {statusLabels[product.status] ?? product.status}
          </p>

          <p>
            <strong>Materials:</strong> {product.materials}
          </p>

          <p>
            <strong>Dimensions:</strong> {product.dimensions}
          </p>
        </article>
      ))}
    </div>
  )}

  <style>
    .grid {
      display: grid;
      gap: 16px;
      grid-template-columns: 1fr;
    }

    .card {
      border: 1px solid #ddd;
      padding: 16px;
      background: white;
    }

    img {
      width: 100%;
      height: auto;
      display: block;
      margin-bottom: 12px;
    }

    @media (min-width: 600px) {
      .grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (min-width: 900px) {
      .grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }
  </style>
</BaseLayout>