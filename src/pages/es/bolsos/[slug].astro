---
import BaseLayout from "../../../layouts/BaseLayout.astro";

export function getStaticPaths() {
  const productModules = import.meta.glob("../../../content/products/*.md", {
    eager: true,
  });

  const products = Object.values(productModules).map(
    (module: any) => module.frontmatter,
  );

  return products.map((product: any) => ({
    params: {
      slug: product.slug,
    },
    props: {
      product,
    },
  }));
}

const { product } = Astro.props;

const statusLabels: Record<string, string> = {
  available: "Disponible",
  sold: "Vendido",
  made_to_order: "Bajo pedido",
};

const whatsappPhone = "34687562377";
const whatsappMessage = `Hola, me interesa este bolso: ${product.name_es}`;
const whatsappUrl = `https://wa.me/${whatsappPhone}?text=${encodeURIComponent(whatsappMessage)}`;
---

<BaseLayout title={`${product.name_es} | La Bambula Saquets`}>
  <article class="product-detail">
    <p class="back-link">
      <a href="/es/bolsos">← Volver a la colección</a>
    </p>

    <section class="product-layout">
      {
        product.main_image && (
          <div class="product-image">
            <img src={product.main_image} alt={product.name_es} />
          </div>
        )
      }

      <div class="product-info">
        <span class={`status status-${product.status}`}>
          {statusLabels[product.status] ?? product.status}
        </span>

        <h2>{product.name_es}</h2>

        <p class="description">{product.long_description_es}</p>

        <dl class="details">
          <div>
            <dt>Materiales</dt>
            <dd>{product.materials}</dd>
          </div>

          <div>
            <dt>Dimensiones</dt>
            <dd>{product.dimensions}</dd>
          </div>
        </dl>

        <a
          class="button"
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
        >
          Consultar por WhatsApp
        </a>

        {
          product.instagram_url && (
            <p class="secondary-link">
              <a
                href={product.instagram_url}
                target="_blank"
                rel="noopener noreferrer"
              >
                Ver en Instagram
              </a>
            </p>
          )
        }
      </div>
    </section>

    {
      Array.isArray(product.images) && product.images.length > 0 && (
        <section class="gallery">
          <h3>Galería</h3>

          <ul>
            {product.images.map((item: any) => (
              <li>
                <img src={item.image} alt={product.name_es} />
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </article>

  <style>
    .back-link {
      margin: 0 0 24px;
      font-size: 0.95rem;
    }

    .product-layout {
      display: grid;
      gap: 28px;
      grid-template-columns: 1fr;
      align-items: start;
    }

    .product-image {
      background: #f7f3ef;
      border: 1px solid var(--color-border);
      padding: 16px;
    }

    .product-image img {
      width: 100%;
      max-height: 720px;
      object-fit: contain;
      display: block;
      background: white;
    }

    .product-info {
      background: var(--color-card);
      padding: 24px;
      border: 1px solid var(--color-border);
    }

    .status {
      display: inline-block;
      margin-bottom: 16px;
      font-size: 0.82rem;
      padding: 5px 11px;
      border: 1px solid var(--color-accent);
      color: var(--color-accent);
      line-height: 1;
    }

    .status-sold {
      border-color: #9b6b5a;
      color: #9b6b5a;
    }

    .status-made_to_order {
      border-color: var(--color-text);
      color: var(--color-text);
    }

    h2 {
      margin: 0 0 16px;
      font-size: 2rem;
      line-height: 1.15;
    }

    .description {
      margin: 0 0 20px;
      line-height: 1.55;
    }

    .details {
      margin: 0 0 24px;
      display: grid;
      gap: 14px;
    }

    .details div {
      display: grid;
      gap: 3px;
    }

    dt {
      font-weight: bold;
    }

    dd {
      margin: 0;
    }

    .button {
      display: inline-block;
      padding: 12px 18px;
      background: var(--color-accent);
      color: white;
      text-decoration: none;
      font-weight: bold;
    }

    .button:hover {
      text-decoration: none;
      opacity: 0.9;
    }

    .secondary-link {
      margin: 18px 0 0;
      font-size: 0.95rem;
    }

    .gallery {
      margin-top: 40px;
    }

    .gallery h3 {
      margin: 0 0 16px;
      font-size: 1.5rem;
    }

    .gallery ul {
      display: grid;
      gap: 18px;
      grid-template-columns: 1fr;
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .gallery li {
      background: #f7f3ef;
      border: 1px solid var(--color-border);
      padding: 12px;
    }

    .gallery img {
      width: 100%;
      aspect-ratio: 4 / 5;
      object-fit: cover;
      display: block;
      background: white;
    }

    @media (min-width: 700px) {
      .gallery ul {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (min-width: 850px) {
      .product-layout {
        grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
      }

      .product-info {
        position: sticky;
        top: 24px;
      }
    }

    @media (max-width: 600px) {
      .product-info {
        padding: 20px;
      }

      h2 {
        font-size: 1.7rem;
      }

      .button {
        width: 100%;
        text-align: center;
      }
    }
  </style>
</BaseLayout>
