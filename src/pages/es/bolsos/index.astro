---
import BaseLayout from "../../../layouts/BaseLayout.astro";

const productModules = import.meta.glob("../../../content/products/*.md", {
  eager: true,
});

const products = Object.values(productModules)
  .map((module: any) => module.frontmatter)
  .sort((a: any, b: any) => (a.order ?? 999) - (b.order ?? 999));

const statusLabels: Record<string, string> = {
  available: "Disponible",
  sold: "Vendido",
  made_to_order: "Bajo pedido",
};
---

<BaseLayout title="Bolsos | La Bambula Saquets">
  <section class="page-header">
    <h2>Bolsos</h2>
    <p>
      Piezas artesanales creadas con calma, materiales seleccionados y carácter mediterráneo.
    </p>
  </section>

  {products.length === 0 ? (
    <p>No hay productos publicados todavía.</p>
  ) : (
    <div class="grid">
      {products.map((product: any) => (
        <article class="card">
          <a class="image-link" href={`/es/bolsos/${product.slug}`}>
            {product.main_image && (
              <img src={product.main_image} alt={product.name_es} />
            )}
          </a>

          <div class="card-content">
            <div class={`status status-${product.status}`}>
              {statusLabels[product.status] ?? product.status}
            </div>

            <h3>
              <a href={`/es/bolsos/${product.slug}`}>
                {product.name_es}
              </a>
            </h3>

            <p class="description">{product.short_description_es}</p>

            <dl class="details">
              <div>
                <dt>Materiales</dt>
                <dd>{product.materials}</dd>
              </div>

              <div>
                <dt>Dimensiones</dt>
                <dd>{product.dimensions}</dd>
              </div>
            </dl>
          </div>
        </article>
      ))}
    </div>
  )}

  <style>
    .page-header {
      max-width: 680px;
      margin-bottom: 28px;
    }

    .page-header h2 {
      margin: 0 0 8px;
      font-size: 2rem;
      line-height: 1.1;
    }

    .page-header p {
      margin: 0;
      line-height: 1.5;
      color: var(--color-text);
    }

    .grid {
      display: grid;
      gap: 24px;
      grid-template-columns: 1fr;
    }

    .card {
      background: var(--color-card);
      border: 1px solid var(--color-border);
      display: flex;
      flex-direction: column;
    }

    .image-link {
      display: block;
      background: #f7f3ef;
      overflow: hidden;
    }

    .image-link img {
      width: 100%;
      aspect-ratio: 4 / 5;
      object-fit: cover;
      display: block;
      transition: transform 180ms ease;
    }

    .image-link:hover img {
      transform: scale(1.02);
    }

    .card-content {
      padding: 18px;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .status {
      align-self: flex-start;
      font-size: 0.8rem;
      padding: 4px 10px;
      border: 1px solid var(--color-accent);
      color: var(--color-accent);
      line-height: 1;
    }

    .status-sold {
      border-color: #9b6b5a;
      color: #9b6b5a;
    }

    .status-made_to_order {
      border-color: var(--color-text);
      color: var(--color-text);
    }

    h3 {
      margin: 0;
      font-size: 1.35rem;
      line-height: 1.2;
    }

    .description {
      margin: 0;
      line-height: 1.45;
    }

    .details {
      margin: 4px 0 0;
      display: grid;
      gap: 8px;
      font-size: 0.95rem;
    }

    .details div {
      display: grid;
      gap: 2px;
    }

    dt {
      font-weight: bold;
    }

    dd {
      margin: 0;
    }

    @media (min-width: 650px) {
      .grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (min-width: 950px) {
      .grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }
  </style>
</BaseLayout>