---
import BaseLayout from "../../layouts/BaseLayout.astro";

const instagramUrl =
  "https://www.instagram.com/labambulasaquets?igsh=MTJpZTFsZ2JuMHQzag==";

const whatsappPhone = "34687562377";
const whatsappMessage =
  "Hola, me gustaría recibir información sobre La Bambula saquets.";
const whatsappUrl = `https://wa.me/${whatsappPhone}?text=${encodeURIComponent(
  whatsappMessage,
)}`;
---

<BaseLayout title="Contacto | La Bambula saquets">
  <section class="contact-page">
    <p class="back-link">
      <a href="/es/bolsos">← Volver a la colección</a>
    </p>

    <div class="contact-card">
      <h2>Contacto</h2>

      <p>
        Si quieres más información sobre una pieza, disponibilidad, encargos o
        cualquier consulta sobre La Bambula saquets, puedes contactar por
        WhatsApp o Instagram.
      </p>

      <p>
        Actualmente la web funciona como escaparate. No hay compra online ni
        pagos desde la página.
      </p>

      <div class="actions">
        <a class="button" href={whatsappUrl} target="_blank" rel="noopener noreferrer">
          Contactar por WhatsApp
        </a>

        <a class="secondary-button" href={instagramUrl} target="_blank" rel="noopener noreferrer">
          Ver Instagram
        </a>
      </div>
    </div>
  </section>

  <style>
    .contact-page {
      max-width: 760px;
      margin: 0 auto;
    }

    .back-link {
      margin: 0 0 24px;
      font-size: 0.95rem;
    }

    .contact-card {
      background: var(--color-card);
      border: 1px solid var(--color-border);
      padding: 28px;
    }

    h2 {
      margin: 0 0 18px;
      font-size: 2rem;
      line-height: 1.15;
    }

    p {
      line-height: 1.55;
    }

    .actions {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 24px;
    }

    .button,
    .secondary-button {
      display: inline-block;
      padding: 12px 18px;
      text-decoration: none;
      font-weight: bold;
    }

    .button {
      background: var(--color-accent);
      color: white;
    }

    .secondary-button {
      border: 1px solid var(--color-accent);
      color: var(--color-accent);
      background: transparent;
    }

    .button:hover,
    .secondary-button:hover {
      text-decoration: none;
      opacity: 0.9;
    }

    @media (max-width: 600px) {
      .contact-card {
        padding: 22px;
      }

      .actions {
        flex-direction: column;
      }

      .button,
      .secondary-button {
        width: 100%;
        text-align: center;
      }
    }
  </style>
</BaseLayout>