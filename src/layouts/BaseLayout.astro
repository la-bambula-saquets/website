---
const { title } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>

    <style>
      :root {
        --color-bg: #f2ebe6;
        --color-text: #4a2e1b;
        --color-accent: #5e6f3f;
        --spacing: 16px;
      }

      body {
        margin: 0;
        font-family: Georgia, serif;
        background: var(--color-bg);
        color: var(--color-text);
      }

      header {
        padding: var(--spacing);
        text-align: center;
        border-bottom: 1px solid #ddd;
      }

      nav {
        margin-top: 8px;
      }

      main {
        padding: var(--spacing);
        max-width: 1100px;
        margin: auto;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      a:hover {
        text-decoration: underline;
      }
      .language-switcher {
        display: inline-flex;
        align-items: center;
        gap: 8px;
      }
    </style>
  </head>

  <body>
    <header>
      <h1>La Bambula Saquets</h1>
      <nav class="language-switcher">
        <a href="/es/bolsos">ES</a>
        <span aria-hidden="true">|</span>
        <a href="/ca/bosses">CA</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>
  </body>
</html>
