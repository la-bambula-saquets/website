---
const { title } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>

    <style>
      :root {
        --color-bg: #f2ebe6;
        --color-text: #4a2e1b;
        --color-accent: #5e6f3f;
        --color-card: #ffffff;
        --color-border: #ddd2ca;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: Georgia, serif;
        background: var(--color-bg);
        color: var(--color-text);
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      a:hover {
        text-decoration: underline;
      }

      .site-header {
        width: 100%;
        border-bottom: 1px solid var(--color-border);
        padding: 28px 16px 24px;
      }

      .header-inner {
        max-width: 1100px;
        margin: 0 auto;
        display: flex;
        justify-content: center;
        align-items: center;
      }

      .brand-link {
        display: block;
        width: fit-content;
        margin: 0 auto;
        line-height: 0;
      }

      .brand-logo {
        display: block;
        width: 280px;
        max-width: 75vw;
        height: auto;
      }

      main {
        max-width: 1100px;
        margin: 0 auto;
        padding: 32px 24px;
      }

      .site-footer {
        border-top: 1px solid var(--color-border);
        padding: 28px 16px;
        margin-top: 48px;
        text-align: center;
        font-size: 0.95rem;
      }

      .footer-nav {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 10px 18px;
        max-width: 900px;
        margin: 0 auto;
      }

      .footer-nav a {
        white-space: nowrap;
      }

      .footer-separator {
        color: var(--color-accent);
      }

      @media (max-width: 600px) {
        .site-header {
          padding: 22px 12px 20px;
        }

        .brand-logo {
          width: 220px;
        }

        main {
          padding: 24px 16px;
        }

        .site-footer {
          padding: 24px 16px;
          margin-top: 40px;
        }

        .footer-nav {
          gap: 8px 14px;
          font-size: 0.9rem;
        }
      }
    </style>
  </head>

  <body>
    <header class="site-header">
      <div class="header-inner">
        <a class="brand-link" href="/es/bolsos" aria-label="La Bambula Saquets">
          <img
            class="brand-logo"
            src="/images/logo.png"
            alt="La Bambula Saquets"
          />
        </a>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <nav class="footer-nav" aria-label="Footer navigation">
        <a href="/es/bolsos">ES</a>
        <span class="footer-separator" aria-hidden="true">|</span>
        <a href="/ca/bosses">CA</a>

        <span class="footer-separator" aria-hidden="true">|</span>
        <a href="#">Instagram</a>

        <span class="footer-separator" aria-hidden="true">|</span>
        <a href="#">WhatsApp</a>

        <span class="footer-separator" aria-hidden="true">|</span>
        <a href="#">Aviso legal</a>

        <span class="footer-separator" aria-hidden="true">|</span>
        <a href="#">Política de privacidad</a>

        <span class="footer-separator" aria-hidden="true">|</span>
        <a href="#">Contacto</a>
      </nav>
    </footer>
  </body>
</html>